{
  "name": "ERP API",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev -c wrangler.local.jsonc",
    "deploy": "wrangler deploy",
    "db:pull": "wrangler d1 export db --remote --output=./database/exports/seed.sql && wrangler d1 execute db --local --file=./database/exports/seed.sql",
    "aidb:pull": "wrangler d1 export ai_db --remote --output=./database/ai/exports/seed.sql && wrangler d1 execute ai_db --local --file=./database/ai/exports/seed.sql",
    "db:migration:create": "wrangler d1 migrations create db",
    "db:migration:local": "wrangler d1 migrations apply db --local",
    "db:migration:remote": "wrangler d1 migrations apply db --remote",
    "aidb:migration:create": "wrangler d1 migrations create ai_db",
    "aidb:migration:local": "wrangler d1 migrations apply ai_db --local",
    "aidb:migration:remote": "wrangler d1 migrations apply ai_db --remote"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "wrangler": "^4.77.0",
    "@elysiajs/jwt": "^1.4.1",
    "@cloudflare/d1": "^1.4.1",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@sinclair/typebox": "^0.34.48",
    "unpdf": "^1.6.2"
  }
}
